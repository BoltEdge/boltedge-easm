# =============================================================================
# Nano EASM — Environment template
# Copy to `.env` (in same dir as docker-compose.yml) and fill in your values.
# =============================================================================
#
# Variables are read by docker-compose.yml. Anything starting with
# NEXT_PUBLIC_ is build-time-only for the frontend — changing it after
# `docker compose up -d` requires a rebuild (`--no-cache`).
#

# ── Database ─────────────────────────────────────────────────────────
DB_NAME=easm
DB_USER=easm_user
DB_PASSWORD=change_me_postgres_password

# ── Backend core ─────────────────────────────────────────────────────
SECRET_KEY=change_me_with_python_secrets_token_hex_32
CORS_ORIGINS=https://nanoasm.com
FRONTEND_URL=https://nanoasm.com
ADMIN_EMAIL=admin@nanoasm.com

# Resend (transactional email — verification, password reset, alerts)
RESEND_API_KEY=re_replace_me
EMAIL_FROM=Nano EASM <no-reply@nanoasm.com>
MONITOR_EMAIL_FROM=Nano EASM Alerts <alerts@nanoasm.com>

# Optional integrations
SHODAN_API_KEY=
GITHUB_TOKEN=

# ── OAuth providers (optional) ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
NEXT_PUBLIC_MICROSOFT_OAUTH_ENABLED=false

# ── Frontend → Backend wiring ────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://nanoasm.com/api

# ─────────────────────────────────────────────────────────────────────
# Billing (Stripe)
# ─────────────────────────────────────────────────────────────────────
#
# Two-flag system:
#   ENABLE_BILLING                 — backend feature flag. When false,
#                                    Stripe endpoints return 503 and the
#                                    free-upgrade flow stays active.
#   NEXT_PUBLIC_ENABLE_BILLING     — frontend feature flag (build-time).
#                                    Hides Stripe UI when false.
#
# Both should match. Test mode keys are sk_test_/pk_test_ — these never
# touch real money. Switch to sk_live_/pk_live_ only after end-to-end
# QA in test mode.
#
ENABLE_BILLING=false
NEXT_PUBLIC_ENABLE_BILLING=false

# Server-side secret. NEVER expose this to the frontend or commit it.
STRIPE_SECRET_KEY=sk_test_replace_me

# Webhook signing secret from Stripe Dashboard → Developers → Webhooks.
# For local dev, use `stripe listen --forward-to localhost:5000/api/billing/stripe-webhook`
# and use the whsec_... it prints.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Browser-safe publishable key. Baked into the frontend bundle at build.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Pinned API version for stability — bump deliberately, not by accident.
STRIPE_API_VERSION=2025-09-30.clover

# Stripe Price IDs — create the Products + Prices in the dashboard, then
# paste the IDs here. One per (plan × cycle).
STRIPE_PRICE_STARTER_MONTHLY=price_replace_me
STRIPE_PRICE_STARTER_ANNUAL=price_replace_me
STRIPE_PRICE_PRO_MONTHLY=price_replace_me
STRIPE_PRICE_PRO_ANNUAL=price_replace_me
STRIPE_PRICE_SILVER_MONTHLY=price_replace_me
STRIPE_PRICE_SILVER_ANNUAL=price_replace_me

# Where Stripe-hosted Checkout sends the user back to.
STRIPE_SUCCESS_URL=https://nanoasm.com/settings/billing?checkout=success
STRIPE_CANCEL_URL=https://nanoasm.com/settings/billing?checkout=cancel
STRIPE_PORTAL_RETURN_URL=https://nanoasm.com/settings/billing
